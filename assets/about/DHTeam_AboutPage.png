/* import fonts */
@import url("https://use.typekit.net/dzz1dvj.css");



span{
font-family: Georgia !important;
}

.heading_font {
font-family: ff-scala-sans-pro,sans-serif !important;
font-weight: 700 !important;
font-style: normal;
}

/* Don't crop splash images on phones */
@media screen and (max-width: 768px) { .splash { background-size: contain; background-repeat: no-repeat; } }


/* Widen Body Area */
.body_copy {
    max-width: 100%;
}

.paragraph_wrapper {
    margin-bottom: 1.5rem;
}

.page {
padding: 0 0 2.5rem 0;
}

header {
    padding-top: 4rem;
}

/*Remove white transparency on BG / Key imagery */
.bg_screen > img {
    display: none;
}

/* Lessen Margin Space on Page Headers */
article h1 {
margin-bottom: 0;
}

/* Add space between primary nav buttons on Home Screen */
a.nav_btn.primary {
margin: .75em;
min-width: 12em;
}

/* Navigation Formatting */
.navbar .title_wrapper {
margin-left: .5em;
}

/* Red Horizontal Rule (Home/About/Etc. pages)*/
.new1{
border-bottom: 3px solid #b1093b;
}

/*Mulan Horizontal Rule (Blue)*/
.new2 {
    border-bottom: 3px solid #1A374C;
}

/*Zhao Horizontal Rule (olive)*/
.new3 {
    border-bottom: 3px solid #323528;
}

/*Western Wing Horizontal Rule (green)*/
.new4 {
    border-bottom: 3px solid #234F38;
}

/*Zhang Horizontal Rule (maroon)*/
.new5 {
    border-bottom: 3px solid #560D2B;
}

/*Peony Horizontal Rule (pink)*/
.new6 {
    border-bottom: 3px solid #A83B53;
}

/*Lute Horizontal Rule (brown)*/
.new7 {
    border-bottom: 3px solid #8C3F0A;
}

/* Hide comments */
#incoming_comments {
display: none;
}

/* Footer */
#footer {
padding-top: 1em;
}

#colophon {
display: none;
}

/* Pre-highlighted navigation menu button */
li.dropdown.mainMenu.ready {background-color:#B20839;}

.navbar .logo {
    margin-right: 1.5em;
    margin-bottom: 3px;
}

@media screen and (max-width: 768px) {
.logo {display: none;}

.navbar .title_wrapper {
margin-left: 20px;
}

}

/* font alterations to Body */
.body_font { 
font-family: Georgia, Times, serif !important; 
}

/* Header Alterations */

article h1 {
text-transform: Uppercase;
}

article h2 {
font-size: 2em;
line-height: normal;
margin-top: .5em !important;
}

h2 {
margin-top: 2.4em !important;
}

article h3{
font-size: 2.4rem !important;
margin-bottom: 2rem !important;
}

article h4{
line-height: .5rem !important;
font-size: 2rem;
}


/*Background color for media/asset pages */
.bg_screen {
    background-color: #f1f1f1
}

/*Hanging indent adjust for play paths/contents */
.path_of > li {
text-indent: 0%;
}

/* Highlight the row of Tables while hovering & Table formatting */

td{
border: solid windowtext 1.0px !important;
}

tr:nth-child(even)
{
background-color: #f2f2f2 !important;
}

tr:hover {
  background-color: #FAC53F !important;
}

table {
border: solid 2px !important;
width: 100%;
}


/*remove history color of visited links in the navigation menu*/
.navbar li.visited>a, .navbar ul.dropdown-menu li.visited>a, #mobileMainMenuSubmenus li.visited>a {
    color: #b3b3b3; !important
}

.navbar li.mainMenu>.mainMenuDropdown>#mainMenuInside>li>ol>li.visited>a:first-child:before, .tocMenu .expandedPage .relationships ol>li.visited>a:first-child:before {
color: #b3b3b3; !important
}


/*fix superscript alignment*/
sup 
{vertical-align: baseline !important;}

/*hide Contents paths*/
.relationships h1 {
display: none;}

ol.path_of {
    display: none;
}

